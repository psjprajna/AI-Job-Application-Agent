{
  "manifest_version": 3,
  "name": "AI Job Application Agent — Autofill",
  "version": "0.1.0",
  "description": "Autofill ATS application forms using content generated by the AI Job Application Agent.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://*.greenhouse.io/*",
    "https://*.lever.co/*",
    "https://*.ashbyhq.com/*",
    "https://*.workday.com/*",
    "https://*.myworkdayjobs.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Job Application Agent"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.greenhouse.io/*",
        "https://*.lever.co/*",
        "https://*.ashbyhq.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
